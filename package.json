{
  "name": "typegres",
  "version": "0.0.1",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts"
    },
    "./config": {
      "import": "./dist/config.mjs",
      "types": "./dist/config.d.mts"
    },
    "./types": {
      "import": "./dist/types/index.mjs",
      "types": "./dist/types/index.d.mts"
    },
    "./sql-builder": {
      "import": "./dist/builder/sql.mjs",
      "types": "./dist/builder/sql.d.mts"
    }
  },
  "bin": {
    "tg": "./src/cli.ts"
  },
  "files": [
    "dist",
    "src"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsdown",
    "codegen": "node --experimental-strip-types src/types/generate.ts",
    "codegen:check": "tmp=$(mktemp -d) && node --experimental-strip-types src/types/generate.ts --out-dir \"$tmp\" && diff -r \"$tmp\" src/types/generated && rm -rf \"$tmp\"",
    "lint": "eslint src",
    "typecheck": "tsgo --noEmit",
    "format": "prettier --write src",
    "test": "vitest run",
    "check": "npm run lint && npm run typecheck && npm run test && npm --prefix examples/basic run check"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.1",
    "@typescript/native-preview": "^7.0.0-dev.20260413.1",
    "eslint": "^10.2.0",
    "prettier": "^3.8.2",
    "tsdown": "^0.21.8",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.4.4",
    "camelcase": "^9.0.0",
    "pg": "^8.20.0"
  }
}
