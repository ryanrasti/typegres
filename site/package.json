{
  "name": "typegres-site",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build:deps": "cd .. && npm run build",
    "build": "npm run build:deps && npm run build:docs && astro build",
    "build:docs": "typedoc && rm -rf public/api/media || true",
    "preview": "astro preview",
    "typecheck": "astro check",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:ui": "vitest --ui",
    "migrate": "node --experimental-strip-types migrate.ts",
    "generate": "tg generate",
    "regen-schema": "npm run migrate && npm run generate"
  },
  "dependencies": {
    "@electric-sql/pglite": "^0.4.4",
    "@monaco-editor/react": "^4.7.0",
    "lucide-react": "^1.14.0",
    "monaco-editor": "^0.54.0",
    "object-inspect": "^1.13.4",
    "pako": "^2.1.0",
    "prism-react-renderer": "^2.4.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-resizable-panels": "^4.11.0",
    "sql-formatter": "^15.6.6",
    "typegres": "file:..",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/mdx": "^5.0.4",
    "@astrojs/react": "^5.0.4",
    "@swc/core": "^1.15.0",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/node": "^25.6.2",
    "@types/object-inspect": "^1.13.0",
    "@types/pako": "^2.0.4",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitest/ui": "^4.1.5",
    "astro": "^6.3.1",
    "autoprefixer": "^10.4.20",
    "esbuild-wasm": "^0.28.0",
    "happy-dom": "^20.0.11",
    "postcss": "^8.4.49",
    "tailwindcss": "^4.2.4",
    "typedoc": "^0.28.13",
    "typescript": "^6.0.3",
    "unplugin-swc": "^1.5.9",
    "vitest": "^4.1.5"
  }
}
