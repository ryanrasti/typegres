{
  "extends": "astro/tsconfigs/strict",
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    },
    // vitest.config sets `globals: true`; pull in the matching
    // ambient types so test files don't need explicit imports.
    "types": ["vitest/globals"]
  },
  "include": ["**/*.ts", "**/*.tsx", "**/*.astro"],
  "exclude": ["node_modules", ".astro", "dist"]
}
